{
    "rust-analyzer.check.overrideCommand": [
        "cargo",
        "check",
        "--quiet",
        "--workspace",
        "--message-format=json",
        "--all-targets",
        "--config=${workspaceFolder}/.cargo/config_build_fastest.toml",
    ],
    "shader-validator.wgsl.enabled": false,
    "git.ignoreLimitWarning": true,
}